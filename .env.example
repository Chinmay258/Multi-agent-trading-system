# =============================================================================
# .env.example — copy to .env and (optionally) tweak.  cp .env.example .env
# =============================================================================
# EVERY configuration variable the system reads is documented below, grouped by
# subsystem, with safe defaults. The whole demo — live public market data +
# paper trading — runs with this file copied VERBATIM and ZERO secrets.
#
# Nothing here is a real credential. NEVER commit your real .env (it is
# .gitignored). Secrets (broker logins, API keys, Slack webhooks) are all
# optional and only needed for features that are out of scope for the keyless
# public demo (live trading, MT5, alerting).
# =============================================================================

# ---------------------------------------------------------------------------
# System identity
# ---------------------------------------------------------------------------
APP_NAME=TradingSystem
ENVIRONMENT=development           # development | staging | production
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR | CRITICAL
DEBUG=false

# THE most important safety flag. paper = simulated money only.
# Never set to `live` without a deliberate, reviewed decision.
TRADING_MODE=paper                # paper (safe default) | live (real money!)

# ---------------------------------------------------------------------------
# Execution + data source selection (the two pluggability seams)
# ---------------------------------------------------------------------------
# Which broker places orders. paper = simulated fills (keyless). mt5 = local
# MetaTrader 5 terminal (real account; out of scope for the public demo).
EXECUTION_BROKER=paper            # paper (default, safe) | mt5

# Where market data comes from (see data_sources/).
#   public = keyless CCXT public OHLCV (DEFAULT — zero secrets)
#   mt5    = local-only, READ-ONLY MetaTrader 5 terminal (never used by the demo)
#   auto   = mt5 if the MetaTrader5 package is installed locally, else public
DATA_SOURCE=public

# ---------------------------------------------------------------------------
# Database (PostgreSQL + TimescaleDB)
# ---------------------------------------------------------------------------
DB_HOST=postgres                  # 'postgres' inside Docker; 'localhost' outside
DB_PORT=5432
DB_NAME=trading_db
DB_USER=trading_user
DB_PASSWORD=trading_pass          # local-only dev password; change for any real deploy
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO_SQL=false                 # log every SQL statement (noisy; dev only)

# ---------------------------------------------------------------------------
# Redis (pub/sub message bus + hot cache)
# ---------------------------------------------------------------------------
REDIS_HOST=redis                  # 'redis' inside Docker; 'localhost' outside
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=                 # uncomment only if your Redis requires auth

# ---------------------------------------------------------------------------
# Exchange (CCXT) — used by the `public` data source and paper pricing
# ---------------------------------------------------------------------------
EXCHANGE_NAME=binance
# EXCHANGE_API_KEY=               # NOT needed for market data or paper trading
# EXCHANGE_API_SECRET=            # only required for LIVE order placement (out of scope)
# EXCHANGE_API_PASSPHRASE=        # some exchanges (OKX) require this for live
# Keep FALSE: real public OHLCV is keyless; the exchange testnet (sandbox=true)
# generally needs API keys and serves thin data. Paper vs. live is controlled by
# TRADING_MODE / EXECUTION_BROKER, not this flag.
EXCHANGE_SANDBOX=false
EXCHANGE_RATE_LIMIT_MS=100
EXCHANGE_REQUEST_TIMEOUT_MS=10000

# ---------------------------------------------------------------------------
# Market data
# ---------------------------------------------------------------------------
MARKET_DATA_SYMBOLS=["BTC/USDT","ETH/USDT"]
# Demo uses higher timeframes to stay gentle on the public API and avoid noise.
# For faster signal turnover use ["1m","5m","1h"] with a smaller poll interval.
MARKET_DATA_OHLCV_TIMEFRAMES=["4h","1d"]
MARKET_DATA_OHLCV_HISTORY_LIMIT=500   # candles fetched on startup for warmup
MARKET_DATA_POLL_INTERVAL_SECONDS=300 # how often to poll the REST endpoint
MARKET_DATA_ORDERBOOK_DEPTH=20

# ---------------------------------------------------------------------------
# Technical Analysis
# ---------------------------------------------------------------------------
TA_RSI_PERIOD=14
TA_RSI_OVERBOUGHT=70.0
TA_RSI_OVERSOLD=30.0
TA_MACD_FAST=12
TA_MACD_SLOW=26
TA_MACD_SIGNAL=9
TA_BB_PERIOD=20
TA_BB_STD_DEV=2.0
TA_EMA_SHORT=9
TA_EMA_LONG=21
TA_MIN_SIGNAL_CONFIDENCE=0.50     # discard signals below this confidence [0..1]
TA_SIGNAL_TTL_SECONDS=300         # how long a signal stays valid downstream
# ML signal engine (XGBoost). When true and a model exists, it replaces the
# rule-based generator; falls back to rules transparently if no model is found.
# DEFAULT false: the Phase-5 walk-forward evaluation showed the ML path does NOT
# beat the simpler rule-based baseline out-of-sample (it overtrades and bleeds on
# fees). See docs/MODEL_CHANGES.md + backtest/results/improved_metrics.json. Flip
# to true to experiment with the ML signal path.
TA_USE_ML_SIGNALS=false
# TA_ML_MODEL_PATH=               # override; default = latest model from ModelRegistry

# ---------------------------------------------------------------------------
# Risk limits (the circuit breakers — treat as sacred)
# ---------------------------------------------------------------------------
RISK_MAX_POSITION_PCT=0.02        # max single position as % of portfolio (2%)
RISK_MAX_OPEN_POSITIONS=3
RISK_MIN_ORDER_SIZE_USD=10.0
RISK_MAX_ORDER_SIZE_USD=1000.0
RISK_MAX_DAILY_LOSS_PCT=0.05      # emergency halt if daily loss > 5%
RISK_MAX_TOTAL_DRAWDOWN_PCT=0.15  # emergency halt if drawdown > 15%
RISK_MAX_DATA_STALENESS_SECONDS=60
RISK_MAX_AGENT_CRASHES=3          # consecutive errors before an agent quarantines
RISK_CRASH_WINDOW_MINUTES=5

# ---------------------------------------------------------------------------
# Paper trading
# ---------------------------------------------------------------------------
PAPER_INITIAL_BALANCE_USD=10000.0

# ---------------------------------------------------------------------------
# Monitoring
# ---------------------------------------------------------------------------
MONITORING_HEARTBEAT_INTERVAL_SECONDS=10
MONITORING_HEARTBEAT_TIMEOUT_SECONDS=30
MONITORING_PROMETHEUS_ENABLED=true
MONITORING_PROMETHEUS_PORT=9090
MONITORING_ALERT_ON_AGENT_CRASH=true
MONITORING_ALERT_ON_DAILY_LOSS_THRESHOLD=true
# MONITORING_SLACK_WEBHOOK_URL=   # optional: enable Slack alerts (a secret — keep out of git)

# ---------------------------------------------------------------------------
# Sentiment (disabled stub in MVP)
# ---------------------------------------------------------------------------
SENTIMENT_ENABLED=false
# SENTIMENT_NEWS_API_KEY=         # optional, only if you implement/enable sentiment
SENTIMENT_FETCH_INTERVAL_SECONDS=300
SENTIMENT_MAX_ARTICLES_PER_FETCH=20

# ---------------------------------------------------------------------------
# API control plane
# ---------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# ---------------------------------------------------------------------------
# MT5 bridge — OPTIONAL, LOCAL-ONLY. Ignored unless EXECUTION_BROKER=mt5 or
# DATA_SOURCE=mt5. The public/cloud demo never uses any of these.
# The EA polls the Python HTTP server below; supply your broker login in the
# MT5 terminal itself, NOT here.
# ---------------------------------------------------------------------------
MT5_HOST=localhost
MT5_PORT=5555
MT5_LISTEN_PORT=5556              # port the Python HTTP server listens on for the EA
MT5_REQUEST_TIMEOUT_MS=15000
MT5_MAX_RETRIES=3
MT5_ENABLED=false
MT5_STOP_LOSS_PCT=0.03
MT5_TAKE_PROFIT_PCT=0.08
MT5_MIN_VOLUME=0.01               # broker lot-size floor for the traded symbol
MT5_MAX_VOLUME=10.0
MT5_VOLUME_STEP=0.01
MT5_POSITION_MONITOR_INTERVAL_SECONDS=5
